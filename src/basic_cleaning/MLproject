name: basic_cleaning
conda_env: conda.yml

entry_points:
  main:
    parameters:

      input_artifact:
        description: Fully-qualified name of the input artifact to download from W&B (e.g. "sample.csv:latest")
        type: str

      output_artifact:
        description: Name of the output artifact to create
        type: str

      output_type:
        description: Type of the output artifact to create
        type: str

      output_description:
        description: Description of the output artifact
        type: str

      min_price:
        description: Minimum accepted nightly price; rows below this are dropped as outliers
        type: float

      max_price:
        description: Maximum accepted nightly price; rows above this are dropped as outliers
        type: float


    command: >-
        python run.py  --input_artifact {input_artifact}  --output_artifact {output_artifact}  --output_type {output_type}  --output_description {output_description}  --min_price {min_price}  --max_price {max_price} 
